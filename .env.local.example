APP_NAME=Facial Recognition TP1
# SETUP: Descargar face_model.pth desde Google Drive y colocarlo en ./models/ antes de ejecutar docker compose up
# Link modelo: https://drive.google.com/file/d/1BrAOj0ZnSvONUGNKTFX9Qv6JfR1TmXLZ
MODEL_NAME=face_model.pth
SIMILARITY_METRIC=cosine
# Threshold calibrado sobre dataset propio (max F1 = 0.2253) + margen de seguridad productivo
SIMILARITY_THRESHOLD=0.35
EMBEDDINGS_PATH=data/embeddings.json
DATA_PATH=data
OUTPUT_PATH=output
# Orígenes permitidos para CORS (coma). Use * en desarrollo.
CORS_ORIGINS="http://localhost:8080"
MODEL_PATH=models
MAX_WORKERS=2
FACE_SIZE=112
# Must match your face embedding model (InsightFace ArcFace is usually 512).
EMBEDDING_DIM=512

# PostgreSQL / pgvector (future integration)
USE_PGVECTOR=true
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=faces
POSTGRES_USER=faces_user
POSTGRES_PASSWORD=faces_pass
