# =====================================================================
# Configuracion del sistema de reconocimiento facial (modo local, sin Docker)
#
# Usar este archivo cuando se corre uvicorn directamente desde el host.
# Copiar como src/.env. Para el flujo con docker compose, usar .env.docker.example.
# =====================================================================

# --- App ---
APP_NAME=Facial Recognition TP1

# --- Modelo ---
# Pack pre-entrenado de InsightFace (RetinaFace + ArcFace).
MODEL_NAME=buffalo_l

# Tamano al que se redimensiona cada cara antes de generar el embedding.
FACE_SIZE=112

# Dimension del vector embedding (ArcFace = 512).
EMBEDDING_DIM=512

# --- Comparacion ---
# "cosine" o "l2".
SIMILARITY_METRIC=cosine

# Umbral para decidir si dos caras son la misma persona.
SIMILARITY_THRESHOLD=0.55

# --- Storage ---
# false = JSON local (mas simple, lo lee el notebook).
# true  = PostgreSQL + pgvector (requiere `docker compose up postgres -d`).
USE_PGVECTOR=true

EMBEDDINGS_PATH=data/embeddings.json

# --- Postgres (solo si USE_PGVECTOR=true) ---
# En modo local apuntamos a localhost (no al hostname "postgres" del compose).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=faces
POSTGRES_USER=faces_user
POSTGRES_PASSWORD=faces_pass

# --- Paths ---
OUTPUT_PATH=output
DATA_PATH=data
MODEL_PATH=models

# --- Concurrencia ---
MAX_WORKERS=2

# --- CORS ---
# Origenes permitidos para CORS. Usar * en desarrollo si hace falta.
CORS_ORIGINS="http://localhost:8080"
