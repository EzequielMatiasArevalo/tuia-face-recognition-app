APP_NAME=Facial Recognition TP1
# Backbone: InsightFace buffalo_l (RetinaFace + ArcFace w600k_r50).
# Dejar MODEL_NAME vacío activa el modo InsightFace completo sin archivo externo.
MODEL_NAME=
MODEL_PATH=models
SIMILARITY_METRIC=cosine
SIMILARITY_THRESHOLD=0.45
EMBEDDINGS_PATH=data/embeddings.json
DATA_PATH=data
OUTPUT_PATH=output
CORS_ORIGINS="http://localhost:8080,http://frontend:8080"
MAX_WORKERS=2
FACE_SIZE=112
# InsightFace ArcFace produce embeddings de 512 dimensiones.
EMBEDDING_DIM=512

# PostgreSQL / pgvector
USE_PGVECTOR=true
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=db_name
POSTGRES_USER=db_user
POSTGRES_PASSWORD=db_password
