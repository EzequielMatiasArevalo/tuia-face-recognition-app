# =====================================================================
# Configuracion del sistema de reconocimiento facial (modo Docker)
#
# Copiar este archivo como .env y ajustar segun necesidad. Los containers
# de docker compose montan este archivo como /app/.env adentro del backend.
# =====================================================================

# --- App ---
# Nombre que muestra el frontend en la UI.
APP_NAME=Facial Recognition TP1

# --- Modelo ---
# Pack pre-entrenado de InsightFace (RetinaFace + ArcFace).
# Otros valores posibles: buffalo_s (mas chico, menos preciso).
MODEL_NAME=buffalo_l

# Tamano al que se redimensiona cada cara antes de generar el embedding.
# 112 es el valor estandar para ArcFace. No cambiar a menos que se cambie de modelo.
FACE_SIZE=112

# Dimension del vector embedding que devuelve el modelo.
# ArcFace de InsightFace siempre devuelve 512. Si se cambia de modelo, ajustar.
EMBEDDING_DIM=512

# --- Comparacion / Identificacion ---
# Metrica para comparar embeddings: "cosine" o "l2".
SIMILARITY_METRIC=cosine

# Umbral para decidir si dos caras son la misma persona.
# - Mas alto (ej. 0.65) = mas estricto (menos falsos positivos, mas "unknown").
# - Mas bajo (ej. 0.45) = mas permisivo (mas matches, mas falsos positivos).
# Valor calibrado para nuestro dataset (ver seccion 9.6 del notebook).
SIMILARITY_THRESHOLD=0.55

# --- Storage de embeddings ---
# Decide donde se guardan los embeddings registrados:
# - false = JSON local (data/embeddings.json) -> el notebook puede leerlos.
# - true  = PostgreSQL + pgvector (recomendado en produccion).
USE_PGVECTOR=false

# Ruta del JSON cuando USE_PGVECTOR=false (relativo a /app dentro del container).
EMBEDDINGS_PATH=data/embeddings.json

# --- Conexion a PostgreSQL (solo se usa si USE_PGVECTOR=true) ---
# Estos valores estan alineados con el servicio "postgres" del docker-compose.yml.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=faces
POSTGRES_USER=faces_user
POSTGRES_PASSWORD=faces_pass

# --- Paths del backend (relativos a /app dentro del container) ---
# Carpeta para uploads y artefactos generados por /predict.
OUTPUT_PATH=output

# Carpeta donde el backend escribe el JSON de embeddings y otros datos.
DATA_PATH=data

# Carpeta donde InsightFace busca el pack del modelo. Si no esta, lo descarga.
MODEL_PATH=models

# --- Concurrencia ---
# Cuantos jobs asincronicos puede procesar el backend en paralelo.
MAX_WORKERS=2

# --- CORS ---
# Origenes permitidos para llamadas al backend desde el navegador.
# Default: el frontend Gradio, accesible desde el host (8080) y desde la red docker.
CORS_ORIGINS="http://localhost:8080,http://frontend:8080"
