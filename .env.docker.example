APP_NAME=Facial Recognition TP1
MODEL_NAME=face_detection.pth
SIMILARITY_METRIC=cosine
SIMILARITY_THRESHOLD=0.55
EMBEDDINGS_PATH=data/embeddings.json
DATA_PATH=data
DATA_AUGMENTATION_PATH=data/dataset_augmentation
OUTPUT_PATH=output
# Orígenes permitidos para CORS (coma). Use * en desarrollo.
CORS_ORIGINS="http://localhost:8080"
MODEL_PATH=models
MODEL_NAME=face_detection.pth
DATASET_PATH=data/aligned_datasets
AUGMENTED_DATASET_PATH=data/augmented_datasets
DATASET_TRAIN_NAME=lfw_train.pt
DATASET_VAL_NAME=lfw_val.pt
MAX_WORKERS=2
FACE_SIZE=112
# Must match your face embedding model (InsightFace ArcFace is usually 512).
EMBEDDING_DIM=512

USE_PGVECTOR=true
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=faces
POSTGRES_USER=faces_user    
POSTGRES_PASSWORD=faces_pass